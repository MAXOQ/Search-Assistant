{
    "manifest_version": 2,
    "name": "Search Assistant",
    "version": "1.0",
    "description": "A simple exension that will quickly search the internet for what you need",
    "permissions": [
        "storage"
    ],
    "icons": {
        "16": "icons/logo.svg",
        "32": "icons/logo.svg",
        "48": "icons/logo.svg",
        "96": "icons/logo.svg"
    },
    "browser_action": {
        "default_popup": "popup.html",
        "default_title": "Search Assistant"
    }
}